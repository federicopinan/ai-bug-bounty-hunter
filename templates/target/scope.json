{
  "version": 1,
  "policyUrl": "https://example.com/program-policy",
  "allowedActions": ["recon", "scan", "fuzz", "exploit", "validate", "report"],
  "defaultActions": ["recon", "scan", "fuzz", "validate", "report"],
  "inScope": [
    {
      "id": "primary-domain",
      "type": "host",
      "pattern": "*.example.com",
      "actions": ["recon", "scan", "fuzz", "validate", "report"],
      "reason": "Wildcard subdomains are listed in program scope."
    }
  ],
  "outOfScope": [
    {
      "id": "admin-exclusion",
      "type": "host",
      "pattern": "admin.example.com",
      "actions": ["recon", "scan", "fuzz", "exploit", "validate", "report"],
      "reason": "Administrative hosts are excluded by policy."
    }
  ]
}
