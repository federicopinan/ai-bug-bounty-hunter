---
import type { ProgramSummary, Severity } from '../lib/types.ts';
import { SEVERITY_ORDER } from '../lib/types.ts';
import SeverityBadge from './SeverityBadge.astro';

interface Props {
  program: ProgramSummary;
}

const { program } = Astro.props;

const sevColors: Record<Severity, string> = {
  Critical: 'bg-kg-dragon-red',
  High: 'bg-kg-autumn',
  Medium: 'bg-kg-boat-yellow',
  Low: 'bg-kg-wave-blue',
  Info: 'bg-kg-fg-faded',
};

const reconKeys = [
  { key: 'subdomains', label: 'sub' },
  { key: 'liveHosts', label: 'live' },
  { key: 'ports', label: 'port' },
  { key: 'techStack', label: 'tech' },
  { key: 'endpoints', label: 'ep' },
  { key: 'jsFiles', label: 'js' },
  { key: 'wayback', label: 'wb' },
] as const;

const topSev = SEVERITY_ORDER.find((s) => program.findingsBySeverity[s] > 0) ?? null;

const presentSeverities = SEVERITY_ORDER.filter((s) => program.findingsBySeverity[s] > 0);
const totalSevAll = SEVERITY_ORDER.reduce((sum, s) => sum + program.findingsBySeverity[s], 0);
---
<a
  href={`/programs/${encodeURIComponent(program.target)}`}
  class="kg-card block bg-kg-bg-elevated border border-kg-border rounded-lg p-5 shadow-kanagawa"
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <div class="min-w-0 flex-1">
      <h3 class="text-kg-fg font-mono font-semibold text-base truncate" title={program.target}>
        {program.target}
      </h3>
      {program.program && (
        <div class="text-kg-fg-faded text-xs font-mono mt-0.5 uppercase tracking-wider">
          {program.program}
        </div>
      )}
    </div>
    {topSev && <SeverityBadge severity={topSev} size="sm" />}
  </div>

  <div class="grid grid-cols-7 gap-1 mb-4">
    {reconKeys.map(({ key, label }) => {
      const value = program.recon[key];
      return (
        <div class="bg-kg-bg-card border border-kg-border rounded px-1.5 py-1 text-center">
          <div class="text-kg-fg text-sm font-mono font-semibold leading-none">{value}</div>
          <div class="text-kg-fg-faded text-[9px] font-mono uppercase tracking-wider mt-0.5">{label}</div>
        </div>
      );
    })}
  </div>

  <div class="flex items-center justify-between text-xs font-mono">
    <div class="flex items-center gap-3 text-kg-fg-muted">
      <span title="New">{program.findingsByStatus.NEW}<span class="text-kg-fg-faded">N</span></span>
      <span title="Validated" class="text-kg-dragon-green">{program.findingsByStatus.VALIDATED}<span class="text-kg-fg-faded/60">V</span></span>
      <span title="Reported" class="text-kg-wave-blue">{program.findingsByStatus.REPORTED}<span class="text-kg-fg-faded/60">R</span></span>
      {program.findingsByStatus.DUPLICATE > 0 && (
        <span title="Duplicate" class="text-kg-dragon-red/80">{program.findingsByStatus.DUPLICATE}<span class="text-kg-fg-faded/60">D</span></span>
      )}
    </div>
    <div class="text-kg-fg-faded">{program.lastActivityRel ?? '—'}</div>
  </div>

  {presentSeverities.length > 0 && (
    <div class="flex h-1 rounded overflow-hidden mt-3 border border-kg-border">
      {presentSeverities.map((s) => {
        const pct = totalSevAll > 0 ? (program.findingsBySeverity[s] / totalSevAll) * 100 : 0;
        const cls = sevColors[s];
        return <div class={cls} style={`width:${pct}%`}></div>;
      })}
    </div>
  )}
</a>